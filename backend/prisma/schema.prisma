generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id           String        @id @default(cuid())
  firstName    String
  lastName     String
  phone        String?
  email        String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
}

model Service {
  id              String          @id @default(cuid())
  name            String          @unique
  price           Int
  duration        Int
  isActive        Boolean         @default(true)
  availableOnline Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  appointments    Appointment[]
  workers         WorkerService[]
}

model Appointment {
  id             String    @id @default(cuid())
  startsAt       DateTime
  status         String
  notes          String?
  clientId       String
  workerId       String
  serviceId      String
  reminderSentAt DateTime?
  reminderType   String?
  source         String    @default("dashboard") // "dashboard" | "online_booking"
  client         Client    @relation(fields: [clientId], references: [id])
  service        Service   @relation(fields: [serviceId], references: [id])
  worker         Worker    @relation(fields: [workerId], references: [id])
}

model Worker {
  id              String           @id @default(cuid())
  firstName       String
  lastName        String
  email           String?
  phone           String?
  roleTitle       String?
  customFields    Json?
  availableOnline Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  appointments    Appointment[]
  schedules       WorkerSchedule[]
  services        WorkerService[]
  scheduleBlocks  ScheduleBlock[]
}

model FormSchema {
  id         String   @id @default(cuid())
  key        String   @unique
  label      String
  entity     String?
  component  String?
  schemaType String   @default("legacy")
  fields     Json     @default("[]")
  fieldRefs  Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model BusinessModel {
  id                String     @id @default(cuid())
  slug              String     @unique
  name              String
  description       String?
  icon              String?
  allowedTriggers   Json
  allowedActions    Json
  templateWorkflows Json?
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  workflows         Workflow[]
}

model Workflow {
  id              String        @id @default(cuid())
  name            String
  description     String?
  status          String        @default("DRAFT")
  businessModelId String
  trigger         Json
  steps           Json
  transitions     Json          @default("[]")
  screens         Json          @default("[]")
  runCount        Int           @default(0)
  lastRunAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  businessModel   BusinessModel @relation(fields: [businessModelId], references: [id], onDelete: Cascade)

  @@index([businessModelId])
  @@index([status])
}

model WorkerSchedule {
  id        String   @id @default(cuid())
  workerId  String
  dayOfWeek Int
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, dayOfWeek])
}

model WorkerService {
  workerId    String
  serviceId   String
  customPrice Int?
  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  worker      Worker  @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@id([workerId, serviceId])
  @@index([serviceId])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  DONE
}

model DashboardWidget {
  id        String   @id @default(cuid())
  userId    String
  title     String
  type      String   // "kpi" | "chart" | "calendar" | "activity" | "workflows" | "table" | "ai_insight"
  config    Json     // Parámetros: { metric, entity, filters, range, grouping, chartType, color }
  layout    Json     // Posición y dimensiones: { x, y, w, h }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Business {
  id                         String   @id @default(cuid())
  name                       String
  slug                       String   @unique
  logo                       String?
  description                String?
  bookingEnabled             Boolean  @default(true)
  bookingPrimaryColor        String   @default("#10b981")
  bookingConfirmationMessage String?  @default("¡Tu reserva ha sido confirmada con éxito!")
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model ScheduleBlock {
  id        String   @id @default(cuid())
  workerId  String
  date      String   // Formato YYYY-MM-DD
  startTime String   // Formato HH:MM
  endTime   String   // Formato HH:MM
  reason    String?
  createdAt DateTime @default(now())
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
}

