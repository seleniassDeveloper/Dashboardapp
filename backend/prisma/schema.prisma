generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id                String             @id @default(cuid())
  firstName         String
  lastName          String
  phone             String?
  email             String?
  notes             String?
  photoUrl          String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  appointments      Appointment[]
  appointmentPhotos AppointmentPhoto[]
  clinicalNotes     ClinicalNote[]
  clinicalHistories ClinicalHistory[]
  consentRequests   ConsentRequest[]
  consentRecords    ConsentRecord[]
  allergies         String?
  medicalNotes      String?
  businessId        String?
  business          Business?          @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Service {
  id                 String                   @id @default(cuid())
  name               String
  description        String?
  category           String?
  price              Int
  duration           Int
  preparationMinutes Int                      @default(0)
  cleanupMinutes     Int                      @default(0)
  depositRequired    Boolean                  @default(false)
  depositAmount      Int                      @default(0)
  color              String                   @default("#10b981")
  status             String                   @default("active") // "active" | "inactive" | "hidden_online"
  isActive           Boolean                  @default(true)
  availableOnline    Boolean                  @default(true)
  requiresApproval   Boolean                  @default(false)
  commissionType     String                   @default("porcentaje") // "porcentaje" | "fijo" | "ninguno"
  commissionValue    Int                      @default(0)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  appointments       Appointment[]
  workers            WorkerService[]
  consumptionRules   ServiceConsumptionRule[]
  consentTemplates   ConsentTemplate[]
  businessId         String?
  business           Business?                @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([name, businessId])
}

model Appointment {
  id             String             @id @default(cuid())
  startsAt       DateTime
  status         String
  notes          String?
  clientId       String
  workerId       String
  serviceId      String
  reminderSentAt DateTime?
  reminderType   String?
  source         String             @default("dashboard") // "dashboard" | "online_booking"
  client         Client             @relation(fields: [clientId], references: [id])
  service        Service            @relation(fields: [serviceId], references: [id])
  worker         Worker             @relation(fields: [workerId], references: [id])
  photos         AppointmentPhoto[]
  clinicalNotes  ClinicalNote[]
  clinicalHistories ClinicalHistory[]
  branchId                 String?
  branch                   Branch?            @relation(fields: [branchId], references: [id])
  businessId               String?
  business                 Business?          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  downpaymentPaid          Int?
  downpaymentStatus        String? // "PENDING" | "PAID" | "REFUNDED"
  downpaymentTransactionId String?
  googleEventId            String?
  consentRequests          ConsentRequest[]
  createdAt                DateTime           @default(now())
  statusHistories          AppointmentStatusHistory[]
}

model Worker {
  id              String           @id @default(cuid())
  firstName       String
  lastName        String
  email           String?
  phone           String?
  roleTitle       String?
  customFields    Json?
  availableOnline Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  appointments    Appointment[]
  schedules       WorkerSchedule[]
  services        WorkerService[]
  scheduleBlocks  ScheduleBlock[]
  clinicalNotes   ClinicalNote[]
  branchId        String?
  branch          Branch?          @relation(fields: [branchId], references: [id])
  salaryPayments  SalaryPayment[]
  businessId      String?
  business        Business?        @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model FormSchema {
  id         String   @id @default(cuid())
  key        String   @unique
  label      String
  entity     String?
  component  String?
  schemaType String   @default("legacy")
  fields     Json     @default("[]")
  fieldRefs  Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model BusinessModel {
  id                String     @id @default(cuid())
  slug              String     @unique
  name              String
  description       String?
  icon              String?
  allowedTriggers   Json
  allowedActions    Json
  templateWorkflows Json?
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  workflows         Workflow[]
}

model Workflow {
  id              String              @id @default(cuid())
  name            String
  description     String?
  status          String              @default("DRAFT")
  businessModelId String?
  trigger         Json
  steps           Json
  transitions     Json                @default("[]")
  screens         Json                @default("[]")
  runCount        Int                 @default(0)
  lastRunAt       DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  businessModel   BusinessModel?      @relation(fields: [businessModelId], references: [id], onDelete: Cascade)
  executions      WorkflowExecution[]

  @@index([businessModelId])
  @@index([status])
}

model WorkflowExecution {
  id          String        @id @default(cuid())
  workflowId  String
  status      String        @default("PENDING") // SUCCESS | FAILED | RUNNING
  triggerType String
  runTimeMs   Int           @default(0)
  createdAt   DateTime      @default(now())
  workflow    Workflow      @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  logs        WorkflowLog[]

  @@index([workflowId])
}

model WorkflowLog {
  id          String            @id @default(cuid())
  executionId String
  nodeName    String
  nodeType    String
  status      String            @default("SUCCESS") // SUCCESS | FAILED
  result      String?
  error       String?
  createdAt   DateTime          @default(now())
  execution   WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
}


model WorkerSchedule {
  id        String   @id @default(cuid())
  workerId  String
  dayOfWeek Int
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, dayOfWeek])
}

model WorkerService {
  workerId    String
  serviceId   String
  customPrice Int?
  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  worker      Worker  @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@id([workerId, serviceId])
  @@index([serviceId])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  DONE
}

model DashboardWidget {
  id        String   @id @default(cuid())
  userId    String
  title     String
  type      String   // "kpi" | "chart" | "calendar" | "activity" | "workflows" | "table" | "ai_insight"
  config    Json     // Parámetros: { metric, entity, filters, range, grouping, chartType, color }
  layout    Json     // Posición y dimensiones: { x, y, w, h }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Business {
  id                         String   @id @default(cuid())
  userId                     String?  // Legacy support
  ownerId                    String?  // UID del creador principal
  name                       String
  slug                       String   @unique
  logo                       String?
  industry                   String?  // Rubro del negocio
  model                      String?  // Modelo de negocio (dentistry, medical_clinic, etc.)
  description                String?
  bookingEnabled             Boolean  @default(true)
  bookingPrimaryColor        String   @default("#10b981")
  bookingConfirmationMessage String?  @default("¡Tu reserva ha sido confirmada con éxito!")
  bookingDownpaymentEnabled  Boolean  @default(false)
  bookingDownpaymentPercent  Int      @default(30)
  bookingDownpaymentAmount   Int?
  bookingDownpaymentMethod   String?  @default("mock_mercadopago")
  googleAccessToken          String?
  googleRefreshToken         String?
  googleCalendarId           String?
  googleBookingUrl           String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  services                   Service[]
  workers                    Worker[]
  appointments               Appointment[]
  clients                    Client[]
  products                   Product[]
  branches                   Branch[]
  members                    BusinessMember[]
  invitations                Invitation[]
  clinicalHistories          ClinicalHistory[]
  consentTemplates           ConsentTemplate[]
  consentRequests            ConsentRequest[]
  consentRecords             ConsentRecord[]
  appointmentStatuses        Json?
  statusHistories            AppointmentStatusHistory[]
}

model ScheduleBlock {
  id        String   @id @default(cuid())
  workerId  String
  date      String   // Formato YYYY-MM-DD
  startTime String   // Formato HH:MM
  endTime   String   // Formato HH:MM
  reason    String?
  createdAt DateTime @default(now())
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
}

model AppointmentPhoto {
  id            String      @id @default(cuid())
  appointmentId String
  clientId      String
  type          String      // "before" | "after"
  imageUrl      String
  createdAt     DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  client        Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ClinicalNote {
  id              String      @id @default(cuid())
  appointmentId   String
  clientId        String
  professionalId  String
  note            String
  recommendations String?
  createdAt       DateTime    @default(now())
  appointment     Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  client          Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  worker          Worker      @relation(fields: [professionalId], references: [id], onDelete: Cascade)
}

model Branch {
  id                String            @id @default(cuid())
  name              String
  address           String?
  phone             String?
  managerId         String?
  isMain            Boolean           @default(false)
  active            Boolean           @default(true)
  createdAt         DateTime          @default(now())
  appointments      Appointment[]
  workers           Worker[]
  expenses          Expense[]
  closings          CashClosing[]
  stockMovements    StockMovement[]
  batches           ProductBatch[]
  branchInventories BranchInventory[]
  purchaseOrders    PurchaseOrder[]
  businessId        String?
  business          Business?         @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([name, businessId])
}

model Expense {
  id          String   @id @default(cuid())
  name        String
  amount      Int
  category    String   // "alquiler" | "servicios" | "insumos" | "marketing" | "otros"
  date        DateTime @default(now())
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

model CashClosing {
  id             String   @id @default(cuid())
  closingDate    DateTime @default(now())
  branchId       String?
  branch         Branch?  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  openedBy       String
  closedBy       String?
  initialCash    Int
  expectedCash   Int
  actualCash     Int
  difference     Int
  notes          String?
  status         String   // "OPEN" | "CLOSED"
  transactions   Json?
  createdAt      DateTime @default(now())
}

model SalaryPayment {
  id             String   @id @default(cuid())
  workerId       String
  baseSalary     Int
  commissionPaid Int
  bonuses        Int      @default(0)
  advances       Int      @default(0)
  deductions     Int      @default(0)
  taxes          Int      @default(0)
  netPaid        Int
  paymentDate    DateTime @default(now())
  notes          String?
  worker         Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
}

model BankMovement {
  id             String   @id @default(cuid())
  date           DateTime
  description    String
  amount         Int
  type           String   // "deposit" | "withdrawal"
  status         String   // "conciliated" | "pending" | "discrepancy"
  reference      String?
  conciliatedAt  DateTime?
  createdAt      DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  businessId String?
  userId     String?
  action     String   // Ej: "invitation_sent", "role_changed"
  entity     String?  // Ej: "BusinessMember", "Appointment"
  entityId   String?
  metadata   Json?    // Datos extra
  createdAt  DateTime @default(now())

  @@index([businessId])
}

model Product {
  id                String                   @id @default(cuid())
  name              String
  category          String
  providerId        String?
  provider          Supplier?                @relation(fields: [providerId], references: [id], onDelete: SetNull)
  costPrice         Int
  salePrice         Int?
  stock             Int                      @default(0)
  minStock          Int                      @default(3)
  maxStock          Int                      @default(10) // Representa stock ideal
  unit              String                   @default("unidad") // "unidad" | "ml" | "gr" | "litro" | "caja"
  barcode           String?
  location          String?
  status            String                   @default("active") // "active" | "inactive"
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  stockMovements    StockMovement[]
  batches           ProductBatch[]
  branchInventories BranchInventory[]
  consumptionRules  ServiceConsumptionRule[]
  orderItems        PurchaseOrderItem[]
  businessId        String?
  business          Business?                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  color             String?
  icon              String?
  label             String?

  @@unique([name, businessId])
}

model Supplier {
  id              String          @id @default(cuid())
  name            String          @unique
  contactName     String?
  phone           String?
  email           String?
  address         String?
  paymentTerms    String?         // "contado", "30d", "65d", etc.
  avgDeliveryDays Int?            @default(7)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  products        Product[]
  batches         ProductBatch[]
  purchaseOrders  PurchaseOrder[]
}

model StockMovement {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  prevQty     Int
  newQty      Int
  diff        Int
  type        String   // "input" | "output" | "adjustment" | "automatic" | "return" | "loss"
  reason      String
  observation String?
  user        String   @default("Admin Aura")
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

model ProductBatch {
  id             String    @id @default(cuid())
  productId      String
  product        Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  batchNumber    String
  supplierId     String?
  supplier       Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  initialQty     Int
  actualQty      Int
  purchaseDate   DateTime  @default(now())
  expirationDate DateTime?
  costPrice      Int
  branchId       String?
  branch         Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  qrCode         String?
  createdAt      DateTime  @default(now())
}

model BranchInventory {
  id         String   @id @default(cuid())
  productId  String
  branchId   String
  stock      Int      @default(0)
  minStock   Int      @default(3)
  idealStock Int      @default(10)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, branchId])
}

model ServiceConsumptionRule {
  id        String   @id @default(cuid())
  serviceId String
  productId String
  quantity  Int      // Cantidad técnica consumida por tratamiento
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serviceId, productId])
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  supplierId  String
  supplier    Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  status      String              @default("DRAFT") // "DRAFT" | "SENT" | "CONFIRMED" | "PARTIAL" | "RECEIVED" | "CANCELLED"
  totalAmount Int                 @default(0)
  notes       String?
  items       PurchaseOrderItem[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model PurchaseOrderItem {
  id          String        @id @default(cuid())
  orderId     String
  order       PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity    Int
  price       Int
  receivedQty Int           @default(0)
}

model User {
  id          String           @id // Firebase UID
  email       String           @unique
  name        String?
  firstName   String?
  lastName    String?
  avatar      String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  memberships BusinessMember[]
}

model BusinessMember {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  roleId     String
  role       String?  // OWNER | ADMIN | MANAGER | PROFESSIONAL etc.
  status     String   @default("ACTIVE") // "ACTIVE" | "INVITED" | "SUSPENDED" | "REMOVED"
  invitedBy  String?  // UID del usuario que invitó
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  roleRel    Role     @relation(fields: [roleId], references: [id])

  @@unique([userId, businessId])
  @@index([userId])
  @@index([businessId])
}

model Invitation {
  id         String   @id @default(cuid())
  businessId String
  email      String
  role       String   // OWNER | ADMIN | MANAGER | PROFESSIONAL etc.
  token      String   @unique
  status     String   @default("PENDING") // PENDING | ACCEPTED | EXPIRED | CANCELLED
  expiresAt  DateTime
  invitedBy  String
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([token])
}

model Role {
  id           String           @id @default(cuid())
  businessId   String?          // Nullable para roles compartidos del sistema
  name         String           // Ej: "Admin / Dueño", "Profesional"
  key          String           // Ej: "owner", "professional"
  description  String?
  isSystemRole Boolean          @default(true)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  members      BusinessMember[]
  permissions  RolePermission[]

  @@unique([key, businessId])
}

model Permission {
  id          String           @id @default(cuid())
  key         String?          @unique
  module      String?          // Ej: "agenda", "finance"
  action      String           @unique // Ej: "agenda.view", "finance.view"
  description String?
  createdAt   DateTime         @default(now())
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model ClinicalHistory {
  id            String       @id @default(cuid())
  businessId    String
  clientId      String
  appointmentId String?
  type          String       // "clinical" | "hair_formula" | "dentistry" | "aesthetic" | "general"
  title         String
  notes         String?
  formulaData   Json?        // Opcional para fórmulas
  clinicalData  Json?        // Opcional para historia clínica
  createdBy     String
  updatedBy     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  business      Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client        Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
}

model ConsentTemplate {
  id                String           @id @default(cuid())
  serviceId         String?
  name              String
  version           Int              @default(1)
  language          String           @default("es")
  body              String           @db.Text // Términos, advertencias y condiciones
  requirements      String?          @db.Text // Qué debe cumplir el cliente
  whatToKnow        String?          @db.Text // Qué se le hará / qué debe saber
  contraindications String?          @db.Text
  preCare           String?          @db.Text
  postCare          String?          @db.Text
  collectAllergies  Boolean          @default(true)
  active            Boolean          @default(true)
  createdBy         String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  businessId        String
  business          Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service           Service?         @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  requests          ConsentRequest[]
  records           ConsentRecord[]
}

model ConsentRequest {
  id              String         @id @default(cuid())
  templateId      String
  templateVersion Int
  clientId        String?
  appointmentId   String?
  token           String         @unique
  channel         String         // "qr" | "link"
  sentTo          String?
  status          String         @default("PENDING") // "PENDING" | "SIGNED" | "EXPIRED" | "REVOKED"
  createdBy       String?
  createdAt       DateTime       @default(now())
  expiresAt       DateTime
  
  businessId      String
  business        Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client          Client?        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointment     Appointment?   @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  template        ConsentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  record          ConsentRecord?
}

model ConsentRecord {
  id                 String          @id @default(cuid())
  requestId          String          @unique
  clientId           String
  templateId         String
  templateVersion    Int
  termsSnapshot      String          @db.Text
  fullNameTyped      String
  signatureImage     String          @db.Text // Trazo Base64 de la firma
  allergies          String?
  medicalDeclarations Json?           // Condiciones, medicamentos, embarazo, etc.
  accepted           Boolean         @default(true)
  acceptedAt         DateTime        @default(now())
  ipAddress          String?
  userAgent          String?
  pdfUrl             String?
  createdAt          DateTime        @default(now())
  
  businessId         String
  business           Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client             Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  template           ConsentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  request            ConsentRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model AppointmentStatusHistory {
  id              String      @id @default(cuid())
  appointmentId   String
  appointment     Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  statusFrom      String
  statusTo        String
  transitionedAt  DateTime    @default(now())
  durationSeconds Int?        // Segundos transcurridos en statusFrom
  businessId      String?
  business        Business?   @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([businessId])
}


