# Copiá a .env (desarrollo local)

NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# PostgreSQL — Neon / Supabase (siempre con SSL en producción)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Orígenes del frontend (CORS). En producción: tu dominio de Vercel.
FRONTEND_URL=http://localhost:5173

# --- Firebase Admin: verifica tokens del cliente ---
# Opción A: archivo JSON (local)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Opción B: JSON en una línea (Railway / hosting)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Solo desarrollo — NUNCA en producción
# AUTH_DISABLED=true

# Email (recordatorios)
EMAIL_HOST=
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Recordatorios automáticos (cron en el servidor)
ENABLE_REMINDERS_JOB=false
REMINDER_MINUTES=120

# IA (opcional)
# OPENAI_API_KEY=
