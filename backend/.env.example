# Copiá a .env

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
PORT=3001

# --- Firebase Admin (backend): verifica el ID token del cliente ---
# Opción A: ruta al JSON de cuenta de servicio (descargado desde Firebase Console → Configuración del proyecto → Cuentas de servicio)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Opción B: JSON completo en una línea (útil en hosting)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Email (recordatorios, etc.)
EMAIL_HOST=
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
