# Copiá a .env (desarrollo local)

NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# PostgreSQL — Neon / Supabase (siempre con SSL en producción)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Orígenes del frontend (CORS). En producción: tu dominio de Vercel.
FRONTEND_URL=http://localhost:5173

# --- Firebase Admin: verifica tokens del cliente ---
# Opción A: archivo JSON (local)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Opción B: JSON en una línea (Railway / hosting)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Solo desarrollo — NUNCA en producción
# AUTH_DISABLED=true

# Paywall / Billing (Fase Piloto)
# BILLING_ENFORCED=false # Cambiar a true cuando se lance oficialmente para bloquear módulos según plan

# MercadoPago API Keys (Suscripciones)
# Dejar vacío o con "mock_" para activar el simulador sandbox en desarrollo local
MP_ACCESS_TOKEN=
APP_BASE_URL=http://localhost:5173

# Email (recordatorios y confirmaciones) -- se envían SIEMPRE por este SMTP propio,
# NO por la API de Gmail (así se evita el scope restringido y la verificación de Google)
EMAIL_HOST=
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Google OAuth (SOLO Calendar). El scope gmail.send fue eliminado.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# En desarrollo: http://localhost:3001/api/public/google/oauth-callback
# En PRODUCCIÓN debe ser tu dominio con HTTPS, p.ej.:
#   https://api.tudominio.com/api/public/google/oauth-callback
# Este valor EXACTO debe estar también en "URIs de redireccionamiento autorizados"
# del cliente OAuth en Google Cloud Console.
GOOGLE_REDIRECT_URI=http://localhost:3001/api/public/google/oauth-callback

# Recordatorios automáticos (cron en el servidor)
ENABLE_REMINDERS_JOB=false
REMINDER_MINUTES=120

# IA (opcional)
# OPENAI_API_KEY=
