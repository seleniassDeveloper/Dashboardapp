# Variables para Railway / Render (producción)
# Pegá en el panel RAW del hosting — no subas este archivo con secretos reales.

NODE_ENV=production
HOST=0.0.0.0
# PORT lo inyecta Railway/Render automáticamente

DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# URL exacta del frontend en Vercel (sin barra final). Varios orígenes: separados por coma.
FRONTEND_URL=https://dashboard-react-rust-eight.vercel.app

# Firebase Admin — JSON completo en UNA línea
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Opcional
# ENABLE_REMINDERS_JOB=true
# OPENAI_API_KEY=
# EMAIL_HOST=
# EMAIL_USER=
# EMAIL_PASS=
