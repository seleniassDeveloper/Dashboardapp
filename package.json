{
  "name": "dashboard-saas",
  "version": "1.0.0",
  "private": true,
  "description": "Dashboard SaaS — frontend (Vercel) + API (Railway)",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix backend\" \"npm run dev --prefix dashboard-react\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:front": "npm run dev --prefix dashboard-react",
    "build:all": "npm run build --prefix backend && npm run build --prefix dashboard-react",
    "build:backend": "npm run build --prefix backend",
    "build:front": "npm run build --prefix dashboard-react"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=20"
  }
}
