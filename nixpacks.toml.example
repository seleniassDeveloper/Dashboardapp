# Solo si Railway usa Nixpacks en lugar de Docker (no recomendado).
# Copiá a nixpacks.toml solo si no usás Dockerfile.
[phases.setup]
nixPkgs = ["nodejs_20", "openssl"]

[phases.install]
cmds = ["cd backend && npm ci"]

[phases.build]
cmds = ["cd backend && npx prisma generate"]

[start]
cmd = "cd backend && npx prisma migrate deploy && node src/server.js"
