# Copiá a .env — mismos valores que en Firebase Console → Ajustes del proyecto → Tus apps → Web
#
# Google Sign-In en local:
# 1. Authentication → Sign-in method → habilitar Google
# 2. Authentication → Settings → Authorized domains → agregar "localhost"
# 3. Abrí la app en http://localhost:5173 (no otro puerto)

VITE_AUTH_DISABLED=false
VITE_API_URL=http://localhost:3001/api

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
